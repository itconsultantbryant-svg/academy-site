PORT=3000
NODE_ENV=development

# Comma-separated allowed origins.
# Required when NODE_ENV=production (boot will fail if unset). Local dev can omit.
# Production (live site): include apex + www if you use both.
# CORS_ORIGIN=https://prinstineacademy.org,https://www.prinstineacademy.org
# Local dev:
# CORS_ORIGIN=http://localhost:5173
DATABASE_URL=
# If PostgreSQL is unavailable, the app can fall back to sqlite (wire in db module)
SQLITE_PATH=./data/app.db

# In production: at least 32 characters (Render Blueprint can auto-generate JWT_SECRET)
JWT_SECRET=local-dev-only-replace-with-a-long-random-string-in-production-env
JWT_EXPIRES_IN=7d

# Upload storage:
# - Local is default when cloudinary vars are missing
# - Cloudinary is used when all three vars below are set
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# First admin user (optional in development; in production both must be set or no admin is auto-created)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your-secure-password
