PORT=3000
# Comma-separated origins, or leave unset to reflect request origin
# CORS_ORIGIN=http://localhost:5173
DATABASE_URL=
# If PostgreSQL is unavailable, the app can fall back to sqlite (wire in db module)
SQLITE_PATH=./data/app.db

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Upload storage:
# - Local is default when cloudinary vars are missing
# - Cloudinary is used when all three vars below are set
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional: create first admin (npm run db:seed)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your-secure-password
