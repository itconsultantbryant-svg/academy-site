# Production frontend: https://prinstineacademy.org
#
# --- API base URL (optional) ---
# Default: leave unset. The app calls `/api` on the same domain (e.g. https://prinstineacademy.org/api); your host proxies to the backend (see vercel.json / netlify.toml).
# Use a full URL only if your host cannot reverse-proxy `/api`:
# VITE_API_URL=https://prinstine-academy-api.onrender.com

# Local dev: Vite proxies /api → Express (see vite.config.js). Override proxy target if needed:
# VITE_API_PROXY_TARGET=http://localhost:3000

# Fine-tuning (optional):
# VITE_API_TIMEOUT_MS=1000
# VITE_REGISTRATION_API_TIMEOUT_MS=45000
# VITE_REGISTRATION_RETRY_ATTEMPTS=3
